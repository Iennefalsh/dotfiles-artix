# Screen locker 
# xscreensaver --no-splash &
xss-lock slock &

# Notifications
# lxqt-notificationd &
dunst &

# Background setter
# xwallpaper --zoom ~/Pictures/wallpaper/fr\ an1.png &
feh --bg-fill ~/.config/wallpaper/fran1.png &
pgrep -a sh | grep wallpapertest || sh ~/.config/wallpapertest.sh & # auto switch

# Compositor
picom --daemon &

# System monitor
# conky -c ~/.config/dtos-conky-lnfls.conf &

lxqt-config-input --load-touchpad & # input profile
exec xset b off & # turn off X bell
lxqt-policykit-agent & # polkit agent
wireplumber & # Audio w/ PipeWire


